{
  "uid": "ai-guard-overview",
  "title": "AI-Guard Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Guard Requests Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "ai_guard_guard_request_total",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Allowed Requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "ai_guard_allowed_requests_total",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "title": "Blocked Requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(ai_guard_blocked_requests_total)",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "title": "Last NLP Risk Score",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "ai_guard_last_nlp_score",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 5,
      "title": "Guard Request Latency p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_guard_guard_request_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 6,
      "title": "Blocked by Firewall",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (blocked_by) (ai_guard_blocked_requests_total)",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    },
    {
      "id": 7,
      "title": "Drift Tasks Submitted",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "ai_guard_drift_tasks_submitted_total",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 12 }
    },
    {
      "id": 8,
      "title": "Network Sample Checks",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "ai_guard_network_sample_checks_total",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 12 }
    },
    {
      "id": 9,
      "title": "Network Samples Blocked",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "ai_guard_network_sample_blocked_total",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 12 }
    }
  ]
}